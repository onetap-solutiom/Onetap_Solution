# Flask Settings
FLASK_APP=app.py
FLASK_ENV=production
PORT=5000

# Security — Generate strong random keys!
# Run: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_THIS_TO_A_STRONG_RANDOM_KEY
JWT_SECRET_KEY=CHANGE_THIS_TO_ANOTHER_STRONG_RANDOM_KEY

# Database (PostgreSQL / Supabase / Railway Postgres)
DB_HOST=your-database-host.com
DB_USER=postgres            # Supabase defaults to postgres
DB_PASSWORD=your_db_password
DB_NAME=postgres            # Supabase default DB name is postgres
DB_PORT=5432

# Frontend URL for CORS (your Vercel URL)
FRONTEND_URL=https://your-app-name.vercel.app
